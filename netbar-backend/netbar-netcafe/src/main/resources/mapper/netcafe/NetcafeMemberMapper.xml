<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ztw.netbar.netcafe.mapper.NetcafeMemberMapper">

    <resultMap type="NetcafeMember" id="NetcafeMemberResult">
        <result property="id"           column="id"            />
        <result property="memberNo"     column="member_no"     />
        <result property="idCard"       column="id_card"       />
        <result property="name"         column="name"          />
        <result property="phone"        column="phone"         />
        <result property="password"     column="password"      />
        <result property="balance"      column="balance"       />
        <result property="totalSpent"   column="total_spent"   />
        <result property="level"        column="level"         />
        <result property="memberType"   column="member_type"   />
        <result property="status"       column="status"        />
        <result property="expireTime"   column="expire_time"   />
        <result property="delFlag"      column="del_flag"      />
        <result property="createBy"     column="create_by"     />
        <result property="createTime"   column="create_time"   />
        <result property="updateBy"     column="update_by"     />
        <result property="updateTime"   column="update_time"   />
        <result property="remark"       column="remark"        />
    </resultMap>

    <sql id="selectNetcafeMemberVo">
        select id, member_no, id_card, name, phone, password, balance, total_spent, level, member_type, status, expire_time, del_flag,
               create_by, create_time, update_by, update_time, remark
        from netcafe_member
    </sql>

    <select id="selectNetcafeMemberById" parameterType="Long" resultMap="NetcafeMemberResult">
        <include refid="selectNetcafeMemberVo"/>
        where id = #{id} and del_flag = '0'
    </select>

    <select id="selectNetcafeMemberByMemberNo" parameterType="String" resultMap="NetcafeMemberResult">
        <include refid="selectNetcafeMemberVo"/>
        where member_no = #{memberNo} and del_flag = '0'
    </select>

    <select id="selectNetcafeMemberByIdCard" parameterType="String" resultMap="NetcafeMemberResult">
        <include refid="selectNetcafeMemberVo"/>
        where id_card = #{idCard} and del_flag = '0'
    </select>

    <select id="selectNetcafeMemberList" parameterType="NetcafeMember" resultMap="NetcafeMemberResult">
        <include refid="selectNetcafeMemberVo"/>
        <where>
            del_flag = '0'
            <if test="memberNo != null and memberNo != ''">
                AND member_no like concat('%', #{memberNo}, '%')
            </if>
            <if test="idCard != null and idCard != ''">
                AND id_card like concat('%', #{idCard}, '%')
            </if>
            <if test="name != null and name != ''">
                AND name like concat('%', #{name}, '%')
            </if>
            <if test="phone != null and phone != ''">
                AND phone like concat('%', #{phone}, '%')
            </if>
            <if test="level != null and level != ''">
                AND level = #{level}
            </if>
            <if test="status != null and status != ''">
                AND status = #{status}
            </if>
        </where>
        order by id desc
    </select>

    <insert id="insertNetcafeMember" parameterType="NetcafeMember" useGeneratedKeys="true" keyProperty="id">
        insert into netcafe_member (
            <if test="memberNo != null and memberNo != ''">member_no, </if>
            <if test="idCard != null and idCard != ''">id_card, </if>
            <if test="name != null and name != ''">name, </if>
            <if test="phone != null and phone != ''">phone, </if>
            <if test="password != null and password != ''">password, </if>
            <if test="balance != null">balance, </if>
            <if test="totalSpent != null">total_spent, </if>
            <if test="level != null and level != ''">level, </if>
            <if test="status != null and status != ''">status, </if>
            <if test="remark != null and remark != ''">remark, </if>
            <if test="createBy != null and createBy != ''">create_by, </if>
            create_time
        )values(
            <if test="memberNo != null and memberNo != ''">#{memberNo}, </if>
            <if test="idCard != null and idCard != ''">#{idCard}, </if>
            <if test="name != null and name != ''">#{name}, </if>
            <if test="phone != null and phone != ''">#{phone}, </if>
            <if test="password != null and password != ''">#{password}, </if>
            <if test="balance != null">#{balance}, </if>
            <if test="totalSpent != null">#{totalSpent}, </if>
            <if test="level != null and level != ''">#{level}, </if>
            <if test="status != null and status != ''">#{status}, </if>
            <if test="remark != null and remark != ''">#{remark}, </if>
            <if test="createBy != null and createBy != ''">#{createBy}, </if>
            sysdate()
        )
    </insert>

    <update id="updateNetcafeMember" parameterType="NetcafeMember">
        update netcafe_member
        <set>
            <if test="memberNo != null and memberNo != ''">member_no = #{memberNo}, </if>
            <if test="idCard != null and idCard != ''">id_card = #{idCard}, </if>
            <if test="name != null and name != ''">name = #{name}, </if>
            <if test="phone != null">phone = #{phone}, </if>
            <if test="password != null and password != ''">password = #{password}, </if>
            <if test="balance != null">balance = #{balance}, </if>
            <if test="totalSpent != null">total_spent = #{totalSpent}, </if>
            <if test="level != null and level != ''">level = #{level}, </if>
            <if test="status != null and status != ''">status = #{status}, </if>
            <if test="remark != null">remark = #{remark}, </if>
            <if test="updateBy != null and updateBy != ''">update_by = #{updateBy}, </if>
            update_time = sysdate()
        </set>
        where id = #{id}
    </update>

    <update id="deleteNetcafeMemberById" parameterType="Long">
        update netcafe_member set del_flag = '1' where id = #{id}
    </update>

    <update id="deleteNetcafeMemberByIds" parameterType="Long">
        update netcafe_member set del_flag = '1' where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <update id="deductMemberBalance">
        update netcafe_member
        set balance = balance - #{amount},
            total_spent = total_spent + #{amount},
            update_time = sysdate()
        where id = #{id} and balance >= #{amount}
    </update>

    <update id="rechargeMemberBalance">
        update netcafe_member
        set balance = balance + #{amount},
            update_time = sysdate()
        where id = #{id}
    </update>

</mapper>
